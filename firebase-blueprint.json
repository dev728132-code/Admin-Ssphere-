{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username"]
    },
    "PaymentRequest": {
      "title": "Payment Request",
      "description": "A payment submission for verification.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "planId": { "type": "string" },
        "planName": { "type": "string" },
        "amount": { "type": "number" },
        "utr": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "adminNote": { "type": "string" }
      },
      "required": ["uid", "productId", "planId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles."
    },
    "/usernames/{username}": {
      "schema": "object",
      "description": "Unique username to UID/Email mapping."
    },
    "/payments/{paymentId}": {
      "schema": "PaymentRequest",
      "description": "Payment verification queue."
    },
    "/admins/{userId}": {
      "schema": "object",
      "description": "Admin white-list."
    }
  }
}
